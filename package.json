{
  "name": "personal-website-monorepo",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev": "npm run dev --workspace @roey/personal-website",
    "dev:personal-website": "npm run dev --workspace @roey/personal-website",
    "dev:finbar": "npm run dev --workspace @roey/finbar",
    "dev:syphon": "npm run dev --workspace @roey/syphon",
    "lint": "eslint \"*.{js,mjs,cjs,ts,mts,cts}\" \"apps/**/*.{astro,js,mjs,cjs,ts,mts,cts}\" \"packages/**/*.{astro,js,mjs,cjs,ts,mts,cts}\""
  },
  "devDependencies": {
    "@eslint/css": "^0.8.1",
    "@eslint/js": "^9.28.0",
    "@typescript-eslint/parser": "^8.33.1",
    "astro-eslint-parser": "^1.2.2",
    "browserslist-config-baseline": "^0.4.0",
    "eslint": "^9.28.0",
    "eslint-plugin-astro": "^0.34.0",
    "globals": "^16.2.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.33.1"
  },
  "browserlist": [
    "extends browserslist-config-baseline"
  ]
}

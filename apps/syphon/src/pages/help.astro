---
import { marked } from "marked";
import ProductLayout from "@roey/site-kit/layouts/ProductLayout.astro";
import { product } from "../product";

const { support } = product;
const userGuideSections = support.userGuideSections.map((section) => ({
  ...section,
  html: marked.parse(section.body),
}));
const troubleshootingSections = support.troubleshootingSections.map(
  (section) => ({
    ...section,
    html: marked.parse(section.body),
  })
);
---

<ProductLayout
  productName={product.name}
  gumroadId={product.gumroadId}
  pageTitle="Help"
  pageDescription={product.metaDescription}
  currentURL={Astro.request.url}
>
  <div class="content-help | padded prose layout stack">
    <h1 class="sr-only">{product.name}: Help</h1>

    <section class="stack">
      <h2>User Guide</h2>
      {
        userGuideSections.map((section) => (
          <section class="stack">
            <h3>{section.title}</h3>
            <div set:html={section.html} />
          </section>
        ))
      }
    </section>

    <section class="stack">
      <h2>Troubleshooting</h2>
      {
        troubleshootingSections.map((section) => (
          <section class="stack">
            <h3>{section.title}</h3>
            <div set:html={section.html} />
          </section>
        ))
      }
    </section>

    <section class="stack">
      <h2>Feedback &amp; Issues</h2>
      <p>
        <a href={support.feedbackUrl}>Submit feedback</a>
      </p>
      {
        support.issueTrackerUrl ? (
          <p>
            <a href={support.issueTrackerUrl}>Open the issue tracker</a>
          </p>
        ) : (
          <p>Issue tracker coming soon.</p>
        )
      }
    </section>

    <section class="stack">
      <h2>Contact</h2>
      <ul>
        {
          support.contactLinks.map((link) => (
            <li>
              <a href={link.href}>{link.label}</a>
            </li>
          ))
        }
      </ul>
    </section>
  </div>
</ProductLayout>

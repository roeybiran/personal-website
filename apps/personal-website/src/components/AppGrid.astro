---
import { getCollection } from "astro:content";
import { featuredProducts } from "@roey/product-catalog";
import AppCard from "@roey/site-kit/components/AppCard.astro";
import finbarIcon from "../content/icons/finbar.png";
import syphonIcon from "../content/icons/syphon.png";

interface Props {
  includeUtilities?: boolean;
}

const { includeUtilities = true } = Astro.props;

const icons = {
  finbar: finbarIcon,
  syphon: syphonIcon,
} as const;

const apps = featuredProducts.map((product) => ({
  name: product.name,
  tagline: product.tagline,
  icon: icons[product.slug],
  slug: product.siteUrl,
}));

const utilities = (await getCollection("utilities")).map((utility) => ({
  ...utility,
  name: utility.data.name,
  tagline: utility.data.tagline,
  icon: utility.data.icon,
  slug: `https://github.com/roeybiran/${utility.data.github}`,
  isSmall: true,
  discontinued: utility.data.discontinued ?? false,
}))
  .sort((a, b) => b.data.releaseDate.getTime() - a.data.releaseDate.getTime());

---

<div class="app-grid">
  <section class="main-apps | stack">
    {apps.map((app) => <AppCard {...app} />)}
  </section>
  {includeUtilities && (
    <section class="misc-apps | padded">
      {utilities.map((app) => <AppCard {...app} />)}
    </section>
  )}
</div>

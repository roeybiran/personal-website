---
import SiteLayout from "@roey/site-kit/layouts/SiteLayout.astro";
import AppGrid from "../components/AppGrid.astro";

const name = "Roey Biran";
const tagline = "Power tools for Mac enthusiasts.";
---

<SiteLayout
  pageTitle="Home"
  pageDescription={`${name}’s personal website`}
  ogImage="/og.jpg"
  currentURL={Astro.request.url}
>
  <h1 class="sr-only">{name}</h1>
  <div class="page-front__content">
    <p class="padded center intrinsic">{tagline}</p>
  </div>
  <AppGrid includeUtilities={false} />
</SiteLayout>

---
import type { CollectionEntry } from "astro:content";
import { getImage, Image } from "astro:assets";
import GitHubButton from "./GitHubButton.astro";
import ExternalLinkIcon from "../assets/external-link.svg";

export interface Props {
  item: CollectionEntry<"items">;
}

const { item } = Astro.props;
const { id, data } = item;
const { title, tagline, date, status, media, stack, press, links } = data;

const hasMeta = stack.length > 0 || Boolean(press?.length);
const isoDate = date?.toISOString();
const dateString = date?.toLocaleDateString("en-US", {
  month: "short",
  year: "numeric",
});
const badgeLabel = status === "discontinued" ? "Discontinued" : undefined;
const badgeTone = status === "discontinued" ? "yellow" : "gray";
const poster = media.type === "video"
  ? await getImage({
      src: media.poster,
      width: 1440,
      format: "webp",
    })
  : undefined;
---

<div
  id={`${id}-popup`}
  class="card__popup"
  popover="auto"
  data-transition-state="idle"
>
  <div class="card__popup-media" data-popup-surface>
    {
      media.type === "video" && (
        <video
          class="card__video"
          src={media.video}
          poster={poster?.src}
          loop
          autoplay
          muted
          playsinline
        />
      )
    }

    {media.type === "image" && (
      <Image class="card__image" src={media.image} alt={title} />
    )}
  </div>

  <div class="card__popup-inner">
    <header class="card__header">
      <p class="card__title">{title}</p>
      {
        isoDate && dateString && (
          <time class="card__date" datetime={isoDate}>
            {dateString}
          </time>
        )
      }
      {
        badgeLabel && (
          <p
            class={`card__status | badge text-xs uppercased theme-${badgeTone}`}
          >
            {badgeLabel}
          </p>
        )
      }
      {tagline && <p class="card__subtitle">{tagline}</p>}
    </header>

    {
      hasMeta && (
        <dl class="card__meta | stack-s">
          {stack.length > 0 && (
            <div class="card__meta-entry card__meta-entry--tools">
              <dt>Tools</dt>
              <div class="card__tools-list | reel">
                {stack.map((tech) => (
                  <dd class="card__badge | badge text-sm theme-plum">{tech}</dd>
                ))}
              </div>
            </div>
          )}
          {press && (
            <div class="card__meta-entry card__meta-entry--press">
              <dt>Press</dt>
              {press.map(({ name, url }) => (
                <dd>
                  <a target="_blank" class="card__link" href={url}>
                    {name}
                  </a>
                </dd>
              ))}
            </div>
          )}
        </dl>
      )
    }

    {
      links.length > 0 && (
        <dl class="card__links | stack-s">
          <dt class="sr-only">Links</dt>
          {links.map(({ label, url, kind }) => (
            <dd>
              {kind === "github" || url.includes("github") ? (
                <GitHubButton url={url} />
              ) : (
                <a class="button button--image" target="_blank" href={url}>
                  {label}
                  <ExternalLinkIcon />
                </a>
              )}
            </dd>
          ))}
        </dl>
      )
    }
  </div>
</div>

<style is:global>
  .main--home {
    .card__popup {
      position: fixed;
      inset-block-start: 50%;
      inset-inline-start: 50%;
      transform: translate(-50%, -50%);
      inline-size: min(var(--size-content-3), calc(100% - (2 * var(--bleed))));
      margin: 0;
      padding: 0;
      overflow: clip;
      opacity: 0;

      background-color: var(--app-bg);
      border: var(--border);
      border-radius: var(--card-radius);
      box-shadow: var(--shadow-5);
      color: inherit;
      transition:
        opacity var(--duration-quick-2) var(--ease-3),
        background-color var(--duration-quick-2) var(--ease-3),
        border-color var(--duration-quick-2) var(--ease-3),
        box-shadow var(--duration-quick-2) var(--ease-3),
        display var(--duration-moderate-1) allow-discrete,
        overlay var(--duration-moderate-1) allow-discrete;
    }

    .card__popup:popover-open {
      opacity: 1;
    }

    .card__popup:popover-open[data-transition-state="opening"],
    .card__popup:popover-open[data-transition-state="closing"] {
      background-color: transparent;
      border-color: transparent;
      box-shadow: none;
    }

    .card__popup::backdrop {
      background-color: transparent;
      backdrop-filter: blur(0);
      transition:
        background-color var(--duration-moderate-1) var(--ease-3),
        backdrop-filter var(--duration-moderate-1) var(--ease-3),
        display var(--duration-moderate-1) allow-discrete,
        overlay var(--duration-moderate-1) allow-discrete;
    }

    .card__popup:popover-open::backdrop {
      background-color: var(--gray-a4);
      backdrop-filter: blur(var(--size-px-2));
    }

    @starting-style {
      .card__popup:popover-open {
        opacity: 0;
      }

      .card__popup:popover-open::backdrop {
        background-color: transparent;
        backdrop-filter: blur(0);
      }
    }

    .card__popup-inner {
      padding: var(--bleed);
      opacity: 0;
      transform: translateY(var(--size-2));
      transition:
        opacity var(--duration-moderate-1) var(--ease-3),
        transform var(--duration-moderate-2) var(--ease-spring-4);

      > * + * {
        border-block-start: var(--border-dashed);
        padding-block-start: var(--size-2);
        margin-block-start: var(--size-2);
      }
    }

    .card__popup:popover-open[data-transition-state="open"] .card__popup-inner {
      opacity: 1;
      transform: none;
      transition-delay: var(--duration-quick-1);
    }

    .card__popup-media {
      position: relative;
      display: grid;
      place-items: center;
      overflow: hidden;
      border-block-end: var(--border);
      background: var(--ui-bg);
      will-change: transform;
    }

    .card__popup[data-transition-state="opening"] .card__popup-media,
    .card__popup[data-transition-state="closing"] .card__popup-media {
      border: var(--border);
      border-radius: var(--card-radius);
    }

    .card__popup-media > * {
      grid-area: 1/1;
    }

    .card__popup-media > :first-child {
      inline-size: 100%;
      block-size: auto;
      min-inline-size: 0;
      min-block-size: 0;
      place-self: center;
    }

    .card__popup-media .card__video {
      object-fit: contain;
    }

    .card__popup-media .card__image {
      inline-size: 100%;
      block-size: auto;
      max-inline-size: 100%;
    }

    ::view-transition-group(root) {
      animation-duration: 1ms;
    }

    ::view-transition-group(card-popup-surface) {
      animation-duration: var(--duration-gentle-2);
      animation-timing-function: var(--ease-spring-4);
    }

    ::view-transition-old(card-popup-surface),
    ::view-transition-new(card-popup-surface) {
      border-radius: var(--card-radius);
    }

    @supports selector(.card:has(.card__popup:popover-open)) {
      .card:has(.card__popup:popover-open) > .card__media {
        opacity: 0;
      }

      .card:has(.card__popup:popover-open) .card__button svg {
        rotate: -45deg;
      }
    }
  }
</style>

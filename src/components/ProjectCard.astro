---
import { Image } from "astro:assets";
import GitHubButton from "./GitHubButton.astro";
import PlusIcon from "../assets/plus.svg";
import ExternalLinkIcon from "../assets/external-link.svg";

export interface Props {
  id: string;
  type: string;
  title: string;
  isoDate?: string;
  dateString?: string;
  stack?: string[];
  subtitle?: string;
  links?: string[];
  responsibilities?: string[];
  press?: { name: string; url: string }[];
  badgeLabel?: string;
  badgeTone?: "gray" | "yellow" | "plum" | "red";
  sectionKey?: string;
  video?: {
    poster: string;
    src: string;
  };
  image?: ImageMetadata;
}

const {
  id,
  title,
  subtitle,
  isoDate,
  dateString,
  links,
  // responsibilities,
  stack = [],
  press,
  badgeLabel,
  badgeTone = "gray",
  sectionKey,
  type,
  image,
  video,
} = Astro.props;

const hasMeta = stack.length > 0 || Boolean(press?.length);
---

<article
  id={id}
  class={`project-card project-card--${type.toLowerCase()}`}
  aria-label={title}
  data-section={sectionKey}
>
  <div id={`${id}-popup`} class="project-card__popup">
    <div class="project-card__popup-inner">
      <header class="project-card__header">
        <p class="project-card__title">{title}</p>
        {
          isoDate && dateString && (
            <time class="project-card__date" datetime={isoDate}>
              {dateString}
            </time>
          )
        }
        {
          badgeLabel && (
            <p class={`project-card__status | badge text-xs uppercased theme-${badgeTone}`}>
              {badgeLabel}
            </p>
          )
        }
        {subtitle && <p class="project-card__subtitle">{subtitle}</p>}
      </header>

      {
        hasMeta && (
          <dl class="project-card__meta | stack-s">
            {
              stack.length > 0 && (
                <div class="project-card__meta-entry project-card__meta-entry--tools">
                  <dt>Tools</dt>
                  <div class="project-card__tools-list | reel">
                    {
                      stack.map((tech) => (
                        <dd class="project-card__badge | badge text-sm theme-plum">
                          {tech}
                        </dd>
                      ))
                    }
                  </div>
                </div>
              )
            }
            {
              press && (
                <div class="project-card__meta-entry project-card__meta-entry--press">
                  <dt>Press</dt>
                  {press.map(({ name, url }) => (
                    <dd>
                      <a target="_blank" class="project-card__link" href={url}>
                        {name}
                      </a>
                    </dd>
                  ))}
                </div>
              )
            }
          </dl>
        )
      }

      {
        links && (
          <dl class="project-card__links | stack-s">
            <dt class="sr-only">Links</dt>
            {links?.map((url: string) => (
              <dd>
                {url.includes("github") ? (
                  <GitHubButton url={url} />
                ) : (
                  <a class="button button--image" target="_blank" href={url}>
                    Visit
                    <ExternalLinkIcon />
                  </a>
                )}
              </dd>
            ))}
          </dl>
        )
      }

    </div>
  </div>

  <div class="project-card__media">
    {
      video && (
        <video
          class="project-card__video"
          src={video.src}
          poster={video.poster}
          loop
          autoplay
          muted
          playsinline
        />
      )
    }

    {image && <Image class="project-card__image" src={image} alt={title} />}

    <button
      class="project-card__button | button button--image button--rounded"
      data-popup={`${id}-popup`}
      aria-label="Open project details"
    >
      <PlusIcon />
    </button>
  </div>
</article>

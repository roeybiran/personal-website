---
import type { CollectionEntry } from "astro:content";
import { getImage, Image } from "astro:assets";
import GitHubButton from "./GitHubButton.astro";
import ExternalLinkIcon from "../assets/external-link.svg";
import PlusIcon from "../assets/plus.svg";
import "./ProjectCard.css";

export interface Props {
  item: CollectionEntry<"items">;
  sectionKey?: string;
}

const { item, sectionKey } = Astro.props;
const { id, data } = item;
const { title, kind, tagline, date, status, media, stack, press, links } = data;

const hasMeta = stack.length > 0 || Boolean(press?.length);
const isInteraction = kind === "interaction";
const popoverId = `${id}-popover`;
const popoverAnchor = `--${id}-popover-anchor`;
const isoDate = date?.toISOString();
const dateString = date?.toLocaleDateString("en-US", {
  month: "short",
  year: "numeric",
});
const badgeLabel = status === "discontinued" ? "Discontinued" : undefined;
const badgeTone = status === "discontinued" ? "yellow" : "gray";
const videos = import.meta.glob<string>("../content/item-media/*.mp4", {
  eager: true,
  import: "default",
  query: "?url",
});
const poster = media.type === "video"
  ? await getImage({
      src: media.poster,
      width: 1440,
      format: "webp",
    })
  : undefined;
const videoSrc = media.type === "video"
  ? videos[`../content/item-media/${media.video.split("/").at(-1)}`]
  : undefined;

if (media.type === "video" && !videoSrc) {
  throw new Error(`Missing video asset for ${title}: ${media.video}`);
}
---

<article
  id={id}
  class={`card card--${kind} | cardlike`}
  data-section={sectionKey}
  data-js-card
>
  <div
    class:list={["card-inner", { card__inner: !isInteraction }]}
    data-js-card-inner
    tabindex="-1"
  >
    <div class="card__media">
      <div class="card__surface" data-card-surface>
        {
          media.type === "video" && (
            <video
              class="card__video"
              src={videoSrc}
              poster={poster?.src}
              loop
              autoplay
              muted
              playsinline
            />
          )
        }

        {media.type === "image" && (
          <Image
            class="card__image"
            src={media.image}
            alt={title}
            loading="lazy"
          />
        )}
      </div>

      {
        isInteraction ? (
          <button
            class="card__open-button glass"
            popovertarget={popoverId}
            style={`anchor-name: ${popoverAnchor}`}
          >
            <span class="sr-only">Open {title}</span>
            <PlusIcon />
          </button>
        ) : (
          <button
            class="card__open-button glass"
            data-js-card-trigger
            aria-expanded="false"
          >
            <span class="sr-only">Open {title}</span>
            <PlusIcon />
          </button>
        )
      }
    </div>

    {
      isInteraction && (
        <div
          id={popoverId}
          class="card__popover"
          popover
          style={`position-anchor: ${popoverAnchor}`}
        >
          <div class="card__popover-inner">
            <p class="card__popover-title">{title}</p>
            {stack.length > 0 && (
              <ul class="card__popover-stack">
                {stack.map((tech) => (
                  <li class="card__badge | badge text-sm theme-plum">{tech}</li>
                ))}
              </ul>
            )}
          </div>
        </div>
      )
    }

    <div class="card__details">
      <header class="card__header">
        <p class="card__title">{title}</p>
        {
          isoDate && dateString && (
            <time class="card__date" datetime={isoDate}>
              {dateString}
            </time>
          )
        }
        {
          badgeLabel && (
            <p
              class={`card__status | badge text-xs uppercased theme-${badgeTone}`}
            >
              {badgeLabel}
            </p>
          )
        }
        {tagline && <p class="card__subtitle">{tagline}</p>}
      </header>

      {
        hasMeta && (
          <dl class="card__meta | stack-s">
            {stack.length > 0 && (
              <div class="card__meta-entry card__meta-entry--tools">
                <dt>Tools</dt>
                <div class="card__tools-list | reel">
                  {stack.map((tech) => (
                    <dd class="card__badge | badge text-sm theme-plum">{tech}</dd>
                  ))}
                </div>
              </div>
            )}
            {press && (
              <div class="card__meta-entry card__meta-entry--press">
                <dt>Press</dt>
                {press.map(({ name, url }) => (
                  <dd>
                    <a target="_blank" class="card__link" href={url}>
                      {name}
                    </a>
                  </dd>
                ))}
              </div>
            )}
          </dl>
        )
      }

      {
        links.length > 0 && (
          <dl class="card__links | stack-s">
            <dt class="sr-only">Links</dt>
            {links.map(({ label, url, kind }) => (
              <dd>
                {kind === "github" || url.includes("github") ? (
                  <GitHubButton url={url} />
                ) : (
                  <a class="button button--image" target="_blank" href={url}>
                    {label}
                    <ExternalLinkIcon />
                  </a>
                )}
              </dd>
            ))}
          </dl>
        )
      }
    </div>
  </div>
</article>

---
import { Image } from "astro:assets";
import ProjectPopup from "./ProjectPopup.astro";
import PlusIcon from "../assets/plus.svg";

export interface Props {
  id: string;
  type: string;
  title: string;
  isoDate?: string;
  dateString?: string;
  stack?: string[];
  subtitle?: string;
  links?: string[];
  responsibilities?: string[];
  press?: { name: string; url: string }[];
  badgeLabel?: string;
  badgeTone?: "gray" | "yellow" | "plum" | "red";
  sectionKey?: string;
  video?: {
    poster: string;
    src: string;
  };
  image?: ImageMetadata;
}

const {
  id,
  title,
  subtitle,
  isoDate,
  dateString,
  links,
  // responsibilities,
  stack = [],
  press,
  badgeLabel,
  badgeTone = "gray",
  sectionKey,
  type,
  image,
  video,
} = Astro.props;

const popupId = `${id}-popup`;
const anchorName = `--${id}-anchor`;
---

<article
  id={id}
  class={`card card--${type.toLowerCase()} | cardlike`}
  data-section={sectionKey}
  style={`anchor-name: ${anchorName};`}
>
  <div class="card__media">
    {
      video && (
        <video
          class="card__video"
          src={video.src}
          poster={video.poster}
          loop
          autoplay
          muted
          playsinline
        />
      )
    }

    {image && <Image class="card__image" src={image} alt={title} />}

    <button
      type="button"
      class="card__button | button button--image button--rounded"
      popovertarget={popupId}
      popovertargetaction="toggle"
    >
      <PlusIcon />
    </button>
  </div>

  <ProjectPopup
    popupId={popupId}
    anchorName={anchorName}
    title={title}
    subtitle={subtitle}
    isoDate={isoDate}
    dateString={dateString}
    links={links}
    stack={stack}
    press={press}
    badgeLabel={badgeLabel}
    badgeTone={badgeTone}
    image={image}
    video={video}
  />
</article>

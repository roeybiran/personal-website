---
import SiteLayout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import ProjectCard from "../components/ProjectCard.astro";

const name = "Roey Biran";
const itemEntries = await getCollection("items");

const apps = itemEntries
  .filter(({ data }) => data.kind === "app")
  .sort((a, b) => a.data.title.localeCompare(b.data.title));

const utilities = itemEntries
  .filter(({ data }) => data.kind === "utility")
  .sort(
    (a, b) => (b.data.date?.getTime() ?? 0) - (a.data.date?.getTime() ?? 0),
  );

const allProjects = itemEntries
  .filter(({ data }) => data.kind === "project" && data.date)
  .sort(
    (a, b) => (b.data.date?.getTime() ?? 0) - (a.data.date?.getTime() ?? 0),
  );

const allInteractions = itemEntries
  .filter(({ data }) => data.kind === "interaction" && data.date)
  .sort(
    (a, b) => (b.data.date?.getTime() ?? 0) - (a.data.date?.getTime() ?? 0),
  );

const allIcons = itemEntries
  .filter(({ data }) => data.kind === "icon" && data.date)
  .sort(
    (a, b) => (b.data.date?.getTime() ?? 0) - (a.data.date?.getTime() ?? 0),
  );

const content: {
  title: string;
  key: string;
  items: CollectionEntry<"items">[];
}[] = [
  {
    title: "Apps",
    key: "apps",
    items: [...apps, ...utilities],
  },
  { title: "Projects", key: "projects", items: allProjects },
  { title: "Interactions", key: "interactions", items: allInteractions },
  { title: "Icons", key: "icons", items: allIcons },
];
---

<SiteLayout
  pageDescription={`${name}’s personal website`}
  currentURL={Astro.request.url}
>
  <h1 class="sr-only">{name}</h1>
  <div class="page-front__content">
    <div class="constrained padded">
      <div class="projects-grid | grid">
        {
          content.map(({ title, key, items }) => (
            <>
              <div class="card card--header | cardlike" data-section={key}>
                <h2 class="projects-grid__section-title | text-secondary">
                  {title}
                </h2>
              </div>
              {items.map((item) => (
                <ProjectCard item={item} sectionKey={key} />
              ))}
            </>
          ))
        }
      </div>
    </div>
  </div>
</SiteLayout>

<script>
  const resetDialogStyles = (dialog: HTMLDialogElement) => {
    dialog.style.removeProperty("filter");
    dialog.style.removeProperty("opacity");
    dialog.style.removeProperty("transform");
    dialog.style.removeProperty("transform-origin");
  };

  const getMiniTransform = (
    dialog: HTMLDialogElement,
    button: HTMLButtonElement,
  ) => {
    const buttonRect = button.getBoundingClientRect();
    const dialogRect = dialog.getBoundingClientRect();

    return `
      translate(-50%, -50%)
      translate(${buttonRect.left - dialogRect.left}px, ${buttonRect.top - dialogRect.top}px)
      scale(${Math.max(0.1, buttonRect.width / dialogRect.width)}, ${Math.max(0.1, buttonRect.height / dialogRect.height)})
    `;
  };

  const animateDialogClose = (
    dialog: HTMLDialogElement,
    button: HTMLButtonElement,
  ) => {
    dialog.getAnimations().forEach((animation) => animation.cancel());
    resetDialogStyles(dialog);

    dialog
      .animate(
        [
          {
            filter: "blur(0)",
            opacity: 1,
            transform: "translate(-50%, -50%)",
            transformOrigin: "0 0",
          },
          {
            filter: "blur(8px)",
            opacity: 0,
            transform: getMiniTransform(dialog, button),
            transformOrigin: "0 0",
          },
        ],
        {
          duration: 120,
          easing: "cubic-bezier(0.55, 0, 1, 0.45)",
        },
      )
      .finished.catch(() => {})
      .finally(() => {
        dialog.close();
        resetDialogStyles(dialog);
      });
  };

  document.addEventListener("click", (event) => {
    const target = event.target;

    if (!(target instanceof Element)) {
      return;
    }

    const openButton = target.closest("[data-js-dialog]");

    if (openButton instanceof HTMLButtonElement) {
      const dialogId = openButton.dataset.jsDialog;
      const dialog = dialogId ? document.getElementById(dialogId) : null;

      if (!(dialog instanceof HTMLDialogElement)) {
        return;
      }

      dialog.getAnimations().forEach((animation) => animation.cancel());
      resetDialogStyles(dialog);
      dialog.showModal();

      const miniTransform = getMiniTransform(dialog, openButton);

      dialog.style.opacity = "1";
      dialog.style.transform = miniTransform;
      dialog.style.transformOrigin = "0 0";

      dialog
        .animate(
          [
            {
              filter: "blur(8px)",
              opacity: 0,
              transform: miniTransform,
              transformOrigin: "0 0",
            },
            {
              filter: "blur(0)",
              opacity: 1,
              transform: "translate(-50%, -50%)",
              transformOrigin: "0 0",
            },
          ],
          {
            duration: 280,
            easing: "cubic-bezier(0.2, 1.45, 0.35, 1)",
          },
        )
        .finished.catch(() => {})
        .finally(() => resetDialogStyles(dialog));

      return;
    }

    const closeButton = target.closest("[data-js-dialog-close]");

    if (closeButton instanceof HTMLButtonElement) {
      const dialog = closeButton.closest("dialog");

      if (!(dialog instanceof HTMLDialogElement) || !dialog.open) {
        return;
      }

      const source = dialog.dataset.jsButton
        ? document.getElementById(dialog.dataset.jsButton)
        : null;

      if (!(source instanceof HTMLButtonElement)) {
        return;
      }

      event.preventDefault();
      animateDialogClose(dialog, source);
    }
  });

  document.addEventListener("cancel", (event) => {
    event.preventDefault();
  });
</script>

<style is:global>
  .page-front__content {
    padding-block: var(--size-4) var(--size-8);
  }

  .main--home {
    --card-enter-opacity-duration: calc(
      var(--sneeze) + var(--duration-quick-2) + var(--duration-quick-2)
    );
    --card-enter-transform-duration: calc(
      var(--sneeze) + var(--duration-gentle-2) + var(--duration-moderate-1)
    );
    --card-enter-stagger: calc(var(--duration-quick-1) + var(--jiffy));

    .projects-grid {
      list-style: none;
      --grid-item-min: var(--size-fluid-8);
      --grid-fit: auto-fit;
      gap: var(--bleed);
      grid-auto-rows: var(--size-12);
    }

    .card {
      opacity: 1;
      transform: translateY(0);
      animation:
        card-appear-opacity var(--card-enter-opacity-duration) var(--ease-2)
          both,
        card-appear-transform var(--card-enter-transform-duration) var(--ease-4)
          both;
      animation-delay: calc(sibling-index() * var(--card-enter-stagger));
    }

    .card--header {
      display: grid;
      place-content: center;
      min-block-size: var(--size-12);
      padding: var(--bleed);
      text-align: center;
    }

    .card--header .projects-grid__section-title {
      font-size: var(--font-size-1);
    }

    .card {
      position: relative;
    }

    .card__media {
      position: relative;
      block-size: 100%;
    }

    .card__surface {
      block-size: 100%;
      overflow: hidden;
      display: grid;
      border: var(--border);
      border-radius: var(--card-radius);
      background: var(--ui-bg);

      > * {
        grid-area: 1/1;
      }

      > :first-child {
        inline-size: 100%;
        block-size: 100%;
        min-inline-size: 0;
        min-block-size: 0;
        place-self: center;
      }
    }

    .card__button {
      position: absolute;
      inset-inline-end: var(--size-1);
      inset-block-end: var(--size-1);
      z-index: 1;
      box-shadow: var(--shadow-5);
    }

    .card__button:hover svg {
      rotate: 18deg;
    }

    .card__video {
      object-fit: cover;
    }

    .card__image {
      object-fit: contain;
      max-inline-size: var(--size-10);
    }

    .card--app .card__image {
      max-inline-size: var(--size-8);
    }

    .card--utility .card__image {
      max-inline-size: var(--size-7);
    }

    .card__subtitle {
      color: var(--text-secondary);
    }

    .card__date {
      font-size: var(--font-size-0);
      color: var(--text-secondary);
    }

    .card__meta {
      font-size: var(--font-size-0);
    }

    .card__meta-entry {
      display: flex;
      flex-direction: column;
    }

    .card__tools-list {
      gap: var(--size-1);
    }

    :where(.card--interaction, .card--icon) .card__date {
      display: none;
    }

    .card__meta-entry--press {
      display: flex;
      flex-direction: column;
    }

    .card__meta-entry--press dd {
      overflow: hidden;
      white-space: nowrap;
      text-overflow: ellipsis;
    }

    .card__link {
      color: var(--text-secondary);
    }
  }

  @keyframes card-appear-opacity {
    from {
      opacity: 0;
    }
  }

  @keyframes card-appear-transform {
    from {
      transform: translateY(var(--size-4));
    }
  }
</style>

---
import SiteLayout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";
import ProjectCard from "../components/ProjectCard.astro";
import type { ProjectItem } from "../types/project-item";

const name = "Roey Biran";
const itemEntries = await getCollection("items");

const formatDate = (date?: Date) =>
  date
    ? {
        date,
        isoDate: date.toISOString(),
        dateString: date.toLocaleDateString("en-US", {
          month: "short",
          year: "numeric",
        }),
      }
    : {};

const apps = itemEntries
  .filter(({ data }) => data.kind === "app")
  .sort((a, b) => a.data.title.localeCompare(b.data.title))
  .map(({ id, data }) => ({
    id,
    type: "App",
    title: data.title,
    subtitle: data.tagline,
    links: data.links.map(({ url }) => url),
    image: data.media.type === "image" ? data.media.image : undefined,
  }));

const utilities = itemEntries
  .filter(({ data }) => data.kind === "utility")
  .sort((a, b) => (b.data.date?.getTime() ?? 0) - (a.data.date?.getTime() ?? 0))
  .map(({ id, data }) => ({
    id,
    type: "Utility",
    title: data.title,
    subtitle: data.tagline,
    links: data.links.map(({ url }) => url),
    image: data.media.type === "image" ? data.media.image : undefined,
    badgeLabel: data.status === "discontinued" ? "Discontinued" : undefined,
    badgeTone: "yellow" as const,
  }));

const allProjects = itemEntries
  .filter(({ data }) => data.kind === "project" && data.date)
  .sort((a, b) => (b.data.date?.getTime() ?? 0) - (a.data.date?.getTime() ?? 0))
  .map(({ id, data }) => ({
    id,
    title: data.title,
    subtitle: data.tagline,
    links: data.links.map(({ url }) => url),
    responsibilities: data.responsibilities,
    stack: data.stack,
    press: data.press,
    type: "Project",
    video:
      data.media.type === "video"
        ? {
            src: data.media.video,
            poster: data.media.poster,
          }
        : undefined,
    ...formatDate(data.date),
  }));

const allInteractions = itemEntries
  .filter(({ data }) => data.kind === "interaction" && data.date)
  .sort((a, b) => (b.data.date?.getTime() ?? 0) - (a.data.date?.getTime() ?? 0))
  .map(({ id, data }) => ({
    id,
    title: data.title,
    responsibilities: data.responsibilities,
    stack: data.stack,
    type: "Interaction",
    video:
      data.media.type === "video"
        ? {
            src: data.media.video,
            poster: data.media.poster,
          }
        : undefined,
    ...formatDate(data.date),
  }));

const allIcons = itemEntries
  .filter(({ data }) => data.kind === "icon" && data.date)
  .sort((a, b) => (b.data.date?.getTime() ?? 0) - (a.data.date?.getTime() ?? 0))
  .map(({ id, data }) => ({
    id,
    title: data.title,
    type: "Icon",
    stack: data.stack,
    image: data.media.type === "image" ? data.media.image : undefined,
    ...formatDate(data.date),
  }));

const content: { title: string; key: string; items: ProjectItem[] }[] = [
  {
    title: "Apps",
    key: "apps",
    items: [
      ...apps.map((app) => ({
        id: app.id,
        type: app.type,
        title: app.title,
        subtitle: app.subtitle,
        links: app.links,
        image: app.image,
      })),
      ...utilities.map((utility) => ({
        id: utility.id,
        type: utility.type,
        title: utility.title,
        subtitle: utility.subtitle,
        links: utility.links,
        image: utility.image,
        badgeLabel: utility.badgeLabel,
        badgeTone: "yellow" as const,
      })),
    ],
  },
  { title: "Projects", key: "projects", items: allProjects },
  { title: "Interactions", key: "interactions", items: allInteractions },
  { title: "Icons", key: "icons", items: allIcons },
];
---

<SiteLayout
  pageDescription={`${name}’s personal website`}
  ogImage="/og.jpg"
  currentURL={Astro.request.url}
>
  <h1 class="sr-only">{name}</h1>
  <div class="page-front__content">
    <div class="constrained padded">
      <div class="projects-grid | grid">
        {
          content.map(({ title, key, items }) => (
            <>
              <div class="card card--header | cardlike" data-section={key}>
                <h2 class="projects-grid__section-title | text-secondary">
                  {title}
                </h2>
              </div>
              {items.map((item) => (
                <ProjectCard item={item} sectionKey={key} />
              ))}
            </>
          ))
        }
      </div>
    </div>
  </div>
</SiteLayout>

<script>
  const TRANSITION_NAME = "card-popup-surface";
  const bypassedPopovers = new WeakSet();

  const setTransitionName = (element, value) => {
    if (element instanceof HTMLElement) {
      element.style.viewTransitionName = value;
    }
  };

  const togglePopover = (popover, nextState) => {
    bypassedPopovers.add(popover);

    if (nextState === "open") {
      popover.showPopover();
      return;
    }

    popover.hidePopover();
  };

  const getTransitionElements = (popover) => {
    const card = popover.closest(".card");
    const source = card?.querySelector("[data-card-surface]");
    const target = popover.matches("[data-popup-surface]") ? popover : null;

    if (!(source instanceof HTMLElement) || !(target instanceof HTMLElement)) {
      return null;
    }

    return { source, target };
  };

  const runPopoverTransition = (popover, nextState) => {
    const elements = getTransitionElements(popover);

    if (!document.startViewTransition || !elements) {
      togglePopover(popover, nextState);
      popover.dataset.transitionState = nextState;
      return Promise.resolve();
    }

    const { source, target } = elements;
    popover.dataset.transitionState = "transitioning";

    if (nextState === "open") {
      setTransitionName(source, TRANSITION_NAME);
    } else {
      setTransitionName(target, TRANSITION_NAME);
    }

    const transition = document.startViewTransition(() => {
      if (nextState === "open") {
        setTransitionName(source, "");
        togglePopover(popover, nextState);
        setTransitionName(target, TRANSITION_NAME);
      } else {
        setTransitionName(target, "");
        togglePopover(popover, nextState);
        setTransitionName(source, TRANSITION_NAME);
      }
    });

    return transition.finished.finally(() => {
      setTransitionName(source, "");
      setTransitionName(target, "");
      popover.dataset.transitionState = nextState;
    });
  };

  document.addEventListener("click", async (event) => {
    const target = event.target;

    if (!(target instanceof Element)) {
      return;
    }

    const button = target.closest("[popovertarget]");

    if (!(button instanceof HTMLButtonElement)) {
      return;
    }

    const popoverId = button.getAttribute("popovertarget");
    const popover = popoverId ? document.getElementById(popoverId) : null;

    if (!(popover instanceof HTMLElement) || !popover.matches("[popover]")) {
      return;
    }

    event.preventDefault();

    const activePopover = document.querySelector(".card__popup:popover-open");

    if (activePopover instanceof HTMLElement && activePopover !== popover) {
      await runPopoverTransition(activePopover, "idle");
    }

    if (popover.matches(":popover-open")) {
      await runPopoverTransition(popover, "idle");
      return;
    }

    await runPopoverTransition(popover, "open");
  });

  for (const popover of document.querySelectorAll(".card__popup")) {
    if (!(popover instanceof HTMLElement)) {
      continue;
    }

    popover.addEventListener("beforetoggle", (event) => {
      if (bypassedPopovers.has(popover)) {
        bypassedPopovers.delete(popover);
        return;
      }

      if (popover.dataset.transitionState === "transitioning") {
        return;
      }

      if (!("newState" in event) || event.newState !== "closed") {
        return;
      }

      event.preventDefault();
      void runPopoverTransition(popover, "idle");
    });

    popover.addEventListener("toggle", () => {
      if (!popover.matches(":popover-open")) {
        popover.dataset.transitionState = "idle";
      }
    });
  }
</script>

<style is:global>
  .page-front__content {
    padding-block: var(--size-4) var(--size-8);
  }

  .main--home {
    .projects-grid {
      list-style: none;
      --grid-item-min: var(--size-content-1);
      --grid-fit: auto-fit;
      gap: var(--bleed);
      grid-auto-rows: var(--size-12);
    }

    .card {
      opacity: 1;
      transform: translateY(0);
      animation:
        card-appear-opacity 0.75s var(--ease-2) both,
        card-appear-transform 1.1s var(--ease-4) both;
      animation-delay: calc(sibling-index() * 90ms);
    }

    .card--header {
      display: grid;
      place-content: center;
      min-block-size: var(--size-12);
      padding: var(--bleed);
      text-align: center;
    }

    .card--header .projects-grid__section-title {
      font-size: var(--font-size-1);
    }

    .card {
      position: relative;
    }

    .card__media {
      block-size: 100%;
      overflow: hidden;
      display: grid;
      border: var(--border);
      border-radius: var(--card-radius);
      background: var(--ui-bg);

      > * {
        grid-area: 1/1;
      }

      > :first-child {
        inline-size: 100%;
        block-size: 100%;
        min-inline-size: 0;
        min-block-size: 0;
        place-self: center;
      }
    }

    .card__button {
      position: relative;
      place-self: flex-end;
      margin-inline-end: var(--size-1);
      margin-block-end: var(--size-1);
      box-shadow: var(--shadow-5);

      svg {
        transition: rotate 0.28s cubic-bezier(0.34, 1.56, 0.64, 1);
      }
    }

    .card__button:hover svg {
      rotate: 18deg;
    }

    .card__video {
      object-fit: cover;
    }

    .card__image {
      object-fit: contain;
      max-inline-size: var(--size-10);
    }

    .card--app .card__image {
      max-inline-size: var(--size-8);
    }

    .card--utility .card__image {
      max-inline-size: var(--size-7);
    }

    .card__subtitle {
      color: var(--text-secondary);
    }

    .card__date {
      font-size: var(--font-size-0);
      color: var(--text-secondary);
    }

    .card__meta {
      font-size: var(--font-size-0);
    }

    .card__meta-entry {
      display: flex;
      flex-direction: column;
    }

    .card__tools-list {
      gap: var(--size-1);
    }

    :where(.card--interaction, .card--icon) .card__date {
      display: none;
    }

    .card__meta-entry--press {
      display: flex;
      flex-direction: column;
    }

    .card__meta-entry--press dd {
      overflow: hidden;
      white-space: nowrap;
      text-overflow: ellipsis;
    }

    .card__link {
      color: var(--text-secondary);
    }
  }

  @keyframes card-appear-opacity {
    from {
      opacity: 0;
    }
  }

  @keyframes card-appear-transform {
    from {
      transform: translateY(var(--size-4));
    }
  }
</style>

---
import SiteLayout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import { Image } from "astro:assets";
import ProjectCard from "../components/ProjectCard.astro";
import GitHubButton from "../components/GitHubButton.astro";
import ExternalLinkIcon from "../assets/external-link.svg";
import "../styles/pages/index.css";

const name = "Roey Biran";
const itemEntries = await getCollection("items");

const apps = itemEntries
  .filter(({ data }) => data.kind === "app")
  .sort((a, b) => b.data.title.localeCompare(a.data.title));

const utilities = itemEntries
  .filter(({ data }) => data.kind === "utility")
  .sort(
    (a, b) => (b.data.date?.getTime() ?? 0) - (a.data.date?.getTime() ?? 0),
  );

const allProjects = itemEntries
  .filter(({ data }) => data.kind === "project" && data.date)
  .sort(
    (a, b) => (b.data.date?.getTime() ?? 0) - (a.data.date?.getTime() ?? 0),
  );

const allInteractions = itemEntries
  .filter(({ data }) => data.kind === "interaction" && data.date)
  .sort(
    (a, b) => (b.data.date?.getTime() ?? 0) - (a.data.date?.getTime() ?? 0),
  );

const allIcons = itemEntries
  .filter(({ data }) => data.kind === "icon" && data.date)
  .sort(
    (a, b) => (b.data.date?.getTime() ?? 0) - (a.data.date?.getTime() ?? 0),
  );

const content: {
  title: string;
  key: string;
  items: CollectionEntry<"items">[];
}[] = [
  {
    title: "Apps",
    key: "apps",
    items: [...apps, ...utilities],
  },
  { title: "Projects", key: "projects", items: allProjects },
  { title: "Interactions", key: "interactions", items: allInteractions },
  { title: "Icons", key: "icons", items: allIcons },
];
---

<SiteLayout
  pageDescription={`${name}’s personal website`}
  currentURL={Astro.request.url}
>
  <h1 class="sr-only">{name}</h1>
  <div class="page-front__content">
    <div class="projects-sections | constrained padded">
      {
        content.map(({ title, key, items }) => (
          <section
            class="projects-section"
            data-section={key}
            aria-labelledby={`${key}-title`}
          >
            <header class="projects-section__header">
              <h2
                id={`${key}-title`}
                class="projects-section__title | text-secondary"
              >
                {title}
              </h2>
            </header>
            {key === "apps" ? (
              <ul class="apps-list">
                {items
                  .filter(({ data }) => data.kind === "app")
                  .map(({ data }) => {
                    const primaryLink = data.links.at(0);
                    const isGitHubLink =
                      primaryLink?.kind === "github" ||
                      primaryLink?.url.includes("github");

                    return (
                      <li class="app-listing">
                        <div class="app-listing__content">
                          {data.status === "discontinued" && (
                            <p class="app-listing__status | badge text-xs uppercased theme-gray">
                              Discontinued
                            </p>
                          )}
                          <h3 class="app-listing__title">{data.title}</h3>
                          {data.tagline && (
                            <p class="app-listing__tagline">{data.tagline}</p>
                          )}
                          {primaryLink && (
                            <div class="app-listing__actions">
                              {isGitHubLink ? (
                                <GitHubButton url={primaryLink.url} />
                              ) : (
                                <a
                                  class="button button--image"
                                  target="_blank"
                                  href={primaryLink.url}
                                >
                                  Learn More
                                  <ExternalLinkIcon />
                                </a>
                              )}
                            </div>
                          )}
                        </div>
                        {data.media.type === "image" && (
                          <Image
                            class="app-listing__image"
                            src={data.media.image}
                            alt={data.title}
                          />
                        )}
                      </li>
                    );
                  })}

                {items
                  .filter(({ data }) => data.kind === "utility")
                  .map(({ data }) => {
                    const primaryLink = data.links.at(0);
                    const isGitHubLink =
                      primaryLink?.kind === "github" ||
                      primaryLink?.url.includes("github");

                    return (
                      <li class="app-listing app-listing--utility">
                        <div class="app-listing__content">
                          {data.status === "discontinued" && (
                            <p class="app-listing__status | badge text-xs uppercased theme-gray">
                              Discontinued
                            </p>
                          )}
                          <h3 class="app-listing__title">{data.title}</h3>
                          {data.tagline && (
                            <p class="app-listing__tagline">{data.tagline}</p>
                          )}
                          {primaryLink && (
                            <div class="app-listing__actions">
                              {isGitHubLink ? (
                                <GitHubButton url={primaryLink.url} small />
                              ) : (
                                <a
                                  class="button button--image"
                                  target="_blank"
                                  href={primaryLink.url}
                                >
                                  Learn More
                                  <ExternalLinkIcon />
                                </a>
                              )}
                            </div>
                          )}
                        </div>
                        {data.media.type === "image" && (
                          <Image
                            class="app-listing__image"
                            src={data.media.image}
                            alt={data.title}
                          />
                        )}
                      </li>
                    );
                  })}
              </ul>
            ) : (
              <ul class="projects-grid | grid">
                {items.map((item) => (
                  <li class="projects-grid__item">
                    <ProjectCard item={item} sectionKey={key} />
                  </li>
                ))}
              </ul>
            )}
          </section>
        ))
      }
    </div>
  </div>
</SiteLayout>

<script>
  import gsap from "gsap";
  import { Flip } from "gsap/Flip";

  gsap.registerPlugin(Flip);

  let activeCard: HTMLElement | null = null;
  let activeFlip: gsap.core.Tween | null = null;
  let backgroundTween: gsap.core.Tween | null = null;
  let elevatedCard: HTMLElement | null = null;
  let elevatedCardItem: HTMLElement | null = null;
  let ignoreNextClick = false;

  const backgroundElements = (card: HTMLElement) =>
    [...document.querySelectorAll<HTMLElement>(".site-header, .card")].filter(
      (element) => element !== card,
    );

  const backgroundBlur = () =>
    getComputedStyle(document.documentElement)
      .getPropertyValue("--size-px-2")
      .trim() || "2px";

  const blurBackground = (card: HTMLElement) => {
    const elements = backgroundElements(card);

    backgroundTween?.kill();
    backgroundTween = gsap.fromTo(
      elements,
      { filter: "blur(0px)" },
      {
        filter: `blur(${backgroundBlur()})`,
        duration: 0.35,
        ease: "power2.inOut",
        overwrite: "auto",
      },
    );
  };

  const clearBackgroundBlur = (card: HTMLElement) => {
    const elements = backgroundElements(card);

    backgroundTween?.kill();
    backgroundTween = gsap.fromTo(
      elements,
      { filter: `blur(${backgroundBlur()})` },
      {
        filter: "blur(0px)",
        duration: 0.35,
        ease: "power2.inOut",
        overwrite: "auto",
        onComplete: () => {
          gsap.set(elements, { clearProps: "filter" });
          backgroundTween = null;
        },
      },
    );
  };

  const animateFlip = (
    card: HTMLElement,
    inner: HTMLElement,
    update: () => void,
    onComplete?: () => void,
    ease = "back.out(1.2)",
  ) => {
    activeFlip?.progress(1).kill();
    elevatedCard?.removeAttribute("data-js-card-elevated");
    elevatedCardItem?.removeAttribute("data-js-card-item-elevated");
    elevatedCard = card;
    elevatedCardItem = card.closest(".projects-grid__item");
    card.setAttribute("data-js-card-elevated", "");
    elevatedCardItem?.setAttribute("data-js-card-item-elevated", "");

    const state = Flip.getState(inner);

    update();

    activeFlip = Flip.from(state, {
      duration: 0.35,
      ease,
      nested: true,
      scale: true,
      onComplete: () => {
        onComplete?.();
        activeFlip = null;
      },
    });
  };

  const activeCardInner = () => {
    const inner = activeCard?.querySelector("[data-js-card-inner]");

    return inner instanceof HTMLElement ? inner : null;
  };

  const openCard = (card: HTMLElement) => {
    const inner = card.querySelector("[data-js-card-inner]");

    if (!(inner instanceof HTMLElement)) {
      return;
    }

    const previousCard = activeCard;

    animateFlip(card, inner, () => {
      previousCard?.removeAttribute("data-js-card-active");
      previousCard?.setAttribute("aria-expanded", "false");
      activeCard = card;
      card.setAttribute("data-js-card-opened", "");
      card.setAttribute("data-js-card-active", "");
      card.setAttribute("aria-expanded", "true");
      blurBackground(card);
    });

    inner.focus();
  };

  const closeCard = () => {
    if (!activeCard) {
      return;
    }

    const card = activeCard;
    const inner = card.querySelector("[data-js-card-inner]");

    if (!(inner instanceof HTMLElement)) {
      card.removeAttribute("data-js-card-active");
      card.removeAttribute("data-js-card-elevated");
      elevatedCardItem?.removeAttribute("data-js-card-item-elevated");
      card.setAttribute("aria-expanded", "false");
      clearBackgroundBlur(card);
      elevatedCard = null;
      elevatedCardItem = null;
      activeCard = null;
      return;
    }

    animateFlip(
      card,
      inner,
      () => {
        card.removeAttribute("data-js-card-active");
        card.setAttribute("aria-expanded", "false");
        activeCard = null;

        clearBackgroundBlur(card);
      },
      () => {
        card.removeAttribute("data-js-card-elevated");
        elevatedCardItem?.removeAttribute("data-js-card-item-elevated");
        elevatedCard = null;
        elevatedCardItem = null;
      },
      "power2.inOut",
    );
  };

  const closeFromOutsidePress = (event: MouseEvent | PointerEvent) => {
    const target = event.target;
    const inner = activeCardInner();

    if (inner && target instanceof Node && !inner.contains(target)) {
      ignoreNextClick = true;
      event.preventDefault();
      event.stopPropagation();
      closeCard();
    }
  };

  const closeFromOutsideClick = (event: MouseEvent) => {
    const target = event.target;
    const inner = activeCardInner();

    if (inner && target instanceof Node && !inner.contains(target)) {
      ignoreNextClick = false;
      event.preventDefault();
      event.stopPropagation();
      closeCard();
    }
  };

  document.addEventListener("pointerdown", closeFromOutsidePress, {
    capture: true,
  });
  document.addEventListener("mousedown", closeFromOutsidePress, {
    capture: true,
  });
  document.addEventListener("click", closeFromOutsideClick, {
    capture: true,
  });

  document.addEventListener("click", (event) => {
    if (ignoreNextClick) {
      ignoreNextClick = false;
      return;
    }

    const target = event.target;

    if (!(target instanceof Element)) {
      return;
    }

    if (activeCard) {
      const inner = activeCardInner();

      if (inner && !inner.contains(target)) {
        event.preventDefault();
        closeCard();
      }

      return;
    }

    const card = target.closest("[data-js-card]");

    if (
      card instanceof HTMLElement &&
      !card.hasAttribute("data-js-card-active")
    ) {
      const interactiveTarget = target.closest("a, button");

      if (!interactiveTarget) {
        event.preventDefault();
        openCard(card);
      }
    }
  });

  document.addEventListener("focusin", () => {
    if (activeCard && !activeCard.contains(document.activeElement)) {
      closeCard();
    }
  });

  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape" && activeCard) {
      event.preventDefault();
      closeCard();
    }
  });
</script>

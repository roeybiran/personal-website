---
import SiteLayout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import ProjectCard from "../components/ProjectCard.astro";

const name = "Roey Biran";
const itemEntries = await getCollection("items");

const apps = itemEntries
  .filter(({ data }) => data.kind === "app")
  .sort((a, b) => a.data.title.localeCompare(b.data.title));

const utilities = itemEntries
  .filter(({ data }) => data.kind === "utility")
  .sort(
    (a, b) => (b.data.date?.getTime() ?? 0) - (a.data.date?.getTime() ?? 0),
  );

const allProjects = itemEntries
  .filter(({ data }) => data.kind === "project" && data.date)
  .sort(
    (a, b) => (b.data.date?.getTime() ?? 0) - (a.data.date?.getTime() ?? 0),
  );

const allInteractions = itemEntries
  .filter(({ data }) => data.kind === "interaction" && data.date)
  .sort(
    (a, b) => (b.data.date?.getTime() ?? 0) - (a.data.date?.getTime() ?? 0),
  );

const allIcons = itemEntries
  .filter(({ data }) => data.kind === "icon" && data.date)
  .sort(
    (a, b) => (b.data.date?.getTime() ?? 0) - (a.data.date?.getTime() ?? 0),
  );

const content: {
  title: string;
  key: string;
  items: CollectionEntry<"items">[];
}[] = [
  {
    title: "Apps",
    key: "apps",
    items: [...apps, ...utilities],
  },
  { title: "Projects", key: "projects", items: allProjects },
  { title: "Interactions", key: "interactions", items: allInteractions },
  { title: "Icons", key: "icons", items: allIcons },
];
---

<SiteLayout
  pageDescription={`${name}’s personal website`}
  currentURL={Astro.request.url}
>
  <h1 class="sr-only">{name}</h1>
  <div class="page-front__content">
    <div class="constrained padded">
      <div class="projects-grid | grid">
        {
          content.map(({ title, key, items }) => (
            <>
              <div class="card card--header | cardlike" data-section={key}>
                <h2 class="projects-grid__section-title | text-secondary">
                  {title}
                </h2>
              </div>
              {items.map((item) => (
                <ProjectCard item={item} sectionKey={key} />
              ))}
            </>
          ))
        }
      </div>
    </div>
  </div>
</SiteLayout>

<script>
  document.addEventListener("click", (event) => {
    const target = event.target;

    if (!(target instanceof Element)) {
      return;
    }

    const button = target.closest("[data-js-expand-card]");

    if (!(button instanceof HTMLButtonElement)) {
      return;
    }

    const card = button.closest(".card");
    const info = button.getAttribute("aria-controls")
      ? document.getElementById(button.getAttribute("aria-controls") ?? "")
      : null;

    if (!(card instanceof HTMLElement) || !(info instanceof HTMLElement)) {
      return;
    }

    const expand = () => {
      const isExpanded = card.toggleAttribute("data-expanded");
      const title = button.dataset.cardTitle ?? "card";

      button.setAttribute("aria-expanded", String(isExpanded));
      button.setAttribute(
        "aria-label",
        `${isExpanded ? "Collapse" : "Expand"} ${title}`,
      );
      info.hidden = !isExpanded;
    };
    const transitionDocument = document as Document & {
      startViewTransition?: (updateCallback: () => void) => void;
    };

    if (transitionDocument.startViewTransition) {
      transitionDocument.startViewTransition(expand);
      return;
    }

    expand();
  });
</script>

<style is:global>
  .page-front__content {
    padding-block: var(--size-4) var(--size-8);
  }

  .main--home {
    --card-enter-opacity-duration: calc(
      var(--sneeze) + var(--duration-quick-2) + var(--duration-quick-2)
    );
    --card-enter-transform-duration: calc(
      var(--sneeze) + var(--duration-gentle-2) + var(--duration-moderate-1)
    );
    --card-enter-stagger: calc(var(--duration-quick-1) + var(--jiffy));

    .projects-grid {
      list-style: none;
      --grid-item-min: var(--size-fluid-8);
      --grid-fit: auto-fit;
      gap: var(--bleed);
      grid-auto-rows: var(--size-12);
      grid-auto-flow: dense;
    }

    .card {
      opacity: 1;
      transform: translateY(0);
      animation:
        card-appear-opacity var(--card-enter-opacity-duration) var(--ease-2)
          both,
        card-appear-transform var(--card-enter-transform-duration) var(--ease-4)
          both;
      animation-delay: calc(sibling-index() * var(--card-enter-stagger));
    }

    .card--header {
      display: grid;
      place-content: center;
      min-block-size: var(--size-12);
      padding: var(--bleed);
      text-align: center;
    }

    .card--header .projects-grid__section-title {
      font-size: var(--font-size-1);
    }

    .card:not(.card--header) {
      position: relative;
      display: flex;
      flex-direction: column;
      min-inline-size: 0;
      overflow: hidden;
    }

    .card__media {
      position: relative;
      flex: 1 1 auto;
      min-block-size: 0;
    }

    .card__surface {
      block-size: 100%;
      overflow: hidden;
      display: grid;
      border: var(--border);
      border-radius: var(--card-radius);
      background: var(--ui-bg);

      > * {
        grid-area: 1/1;
      }

      > :first-child {
        inline-size: 100%;
        block-size: 100%;
        min-inline-size: 0;
        min-block-size: 0;
        place-self: center;
      }
    }

    .card__button {
      position: absolute;
      inset-inline-end: var(--size-1);
      inset-block-end: var(--size-1);
      z-index: 1;
      background: var(--sand-3a);
      backdrop-filter: blur(var(--size-3));
      box-shadow: var(--shadow-5);
    }

    .card__button:hover {
      background: var(--sand-3a);
    }

    .card__button:hover svg {
      rotate: 18deg;
    }

    .card[data-expanded] {
      grid-row: span 2;
    }

    @media (width >= 48rem) {
      .card[data-expanded] {
        grid-column: span 2;
      }
    }

    .card[data-expanded] .card__button svg {
      rotate: 45deg;
    }

    .card__info {
      padding: var(--bleed);
      border-inline: var(--border);
      border-block-end: var(--border);
      border-end-start-radius: var(--card-radius);
      border-end-end-radius: var(--card-radius);
      background: var(--app-bg);
    }

    .card__info > * + * {
      border-block-start: var(--border-dashed);
      padding-block-start: var(--size-2);
      margin-block-start: var(--size-2);
    }

    .card[data-expanded] .card__surface {
      border-end-start-radius: 0;
      border-end-end-radius: 0;
    }

    .card__video {
      object-fit: cover;
    }

    .card__image {
      object-fit: contain;
      max-inline-size: var(--size-10);
    }

    .card--app .card__image {
      max-inline-size: var(--size-8);
    }

    .card--utility .card__image {
      max-inline-size: var(--size-7);
    }

    .card__subtitle {
      color: var(--text-secondary);
    }

    .card__date {
      font-size: var(--font-size-0);
      color: var(--text-secondary);
    }

    .card__meta {
      font-size: var(--font-size-0);
    }

    .card__meta-entry {
      display: flex;
      flex-direction: column;
    }

    .card__tools-list {
      gap: var(--size-1);
    }

    :where(.card--interaction, .card--icon) .card__date {
      display: none;
    }

    .card__meta-entry--press {
      display: flex;
      flex-direction: column;
    }

    .card__meta-entry--press dd {
      overflow: hidden;
      white-space: nowrap;
      text-overflow: ellipsis;
    }

    .card__link {
      color: var(--text-secondary);
    }
  }

  @keyframes card-appear-opacity {
    from {
      opacity: 0;
    }
  }

  @keyframes card-appear-transform {
    from {
      transform: translateY(var(--size-4));
    }
  }
</style>

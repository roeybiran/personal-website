---
import SiteLayout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";
import ProjectCard from "../components/ProjectCard.astro";

const name = "Roey Biran";

const apps = [...(await getCollection("apps"))]
  .sort((a, b) => a.id.localeCompare(b.id))
  .map((app) => ({
    id: `app-${app.id}`,
    type: "App",
    image: app.data.icon,
    name: app.data.name,
    tagline: app.data.tagline,
    links: [app.data.siteUrl],
  }));

const utilities = (await getCollection("utilities"))
  .map((utility) => ({
    id: `utility-${utility.id}`,
    type: "Utility",
    image: utility.data.icon,
    name: utility.data.name,
    tagline: utility.data.tagline,
    links: [`https://github.com/roeybiran/${utility.data.github}`],
    discontinued: utility.data.discontinued ?? false,
    releaseDate: utility.data.releaseDate,
  }))
  .sort((a, b) => b.releaseDate.getTime() - a.releaseDate.getTime());

const projects = await getCollection("projects");
const interactions = await getCollection("interactions");
const icons = await getCollection("icons");

const allProjects = [...projects]
  .map(({ id, data }) => {
    const links = [];

    if (data.url) {
      links.push(data.url);
    }
    if (data.github) {
      links.push(`https://github.com/${data.github}`);
    }

    return {
      id,
      title: data.title,
      subtitle: data.tagline,
      date: data.date,
      isoDate: data.date.toISOString(),
      dateString: data.date.toLocaleDateString("en-US", {
        month: "short",
        year: "numeric",
      }),
      links,
      responsibilities: data.responsibilities,
      stack: data.stack,
      press: data.press,
      type: "Project",
      video: {
        src: `/projects/${id}.mp4`,
        poster: `/projects/${id}-poster.jpg`,
      },
    };
  })
  .sort((a, b) => b.date.getTime() - a.date.getTime());

const allInteractions = [...interactions]
  .map(({ id, data }) => ({
    id,
    title: data.title,
    date: data.date,
    isoDate: data.date.toISOString(),
    dateString: data.date.toLocaleDateString("en-US", {
      month: "short",
      year: "numeric",
    }),
    responsibilities: data.responsibilities,
    stack: data.stack,
    type: "Interaction",
    video: {
      src: `/interactions/${id}.mp4`,
      poster: `/interactions/${id}-poster.jpg`,
    },
  }))
  .sort((a, b) => b.date.getTime() - a.date.getTime());

const allIcons = [...icons]
  .map(({ id, data }) => ({
    id,
    title: data.title,
    type: "Icon",
    date: data.date,
    isoDate: data.date.toISOString(),
    dateString: data.date.toLocaleDateString("en-US", {
      month: "short",
      year: "numeric",
    }),
    stack: data.stack,
    image: data.image,
  }))
  .sort((a, b) => b.date.getTime() - a.date.getTime());

const content = [
  {
    title: "Apps",
    key: "apps",
    items: [
      ...apps.map((app) => ({
        id: app.id,
        type: app.type,
        title: app.name,
        subtitle: app.tagline,
        links: app.links,
        image: app.image,
      })),
      ...utilities.map((utility) => ({
        id: utility.id,
        type: utility.type,
        title: utility.name,
        subtitle: utility.tagline,
        links: utility.links,
        image: utility.image,
        badgeLabel: utility.discontinued ? "Discontinued" : undefined,
        badgeTone: "yellow" as const,
      })),
    ],
  },
  { title: "Projects", key: "projects", items: allProjects },
  { title: "Interactions", key: "interactions", items: allInteractions },
  { title: "Icons", key: "icons", items: allIcons },
];
---

<SiteLayout
  pageDescription={`${name}’s personal website`}
  ogImage="/og.jpg"
  currentURL={Astro.request.url}
>
  <h1 class="sr-only">{name}</h1>
  <div class="page-front__content">
    <div class="constrained padded">
      <div class="projects-grid | grid">
        {
          content.map(({ title, key, items }) => (
            <>
              <div class="card card--header | cardlike" data-section={key}>
                <h2 class="projects-grid__section-title | text-secondary">
                  {title}
                </h2>
              </div>
              {items.map((item) => (
                <ProjectCard {...item} sectionKey={key} />
              ))}
            </>
          ))
        }
      </div>
    </div>
  </div>
</SiteLayout>

<style is:global>
  .page-front__content {
    padding-block: var(--size-4) var(--size-8);
  }

  .main--home {
    .projects-grid {
      list-style: none;
      --grid-item-min: var(--size-content-1);
      --grid-fit: auto-fit;
      gap: var(--bleed);
      grid-auto-rows: var(--size-12);
    }

    .card {
      opacity: 1;
      transform: translateY(0);
      animation:
        card-appear-opacity 0.75s var(--ease-2) both,
        card-appear-transform 1.1s var(--ease-4) both;
      animation-delay: calc(sibling-index() * 90ms);
    }

    .card--header {
      display: grid;
      place-content: center;
      min-block-size: var(--size-12);
      padding: var(--bleed);
      text-align: center;
    }

    .card--header .projects-grid__section-title {
      font-size: var(--font-size-1);
    }

    .card {
      position: relative;
    }

    .card__media {
      block-size: 100%;
      overflow: hidden;
      display: grid;
      border: var(--border);
      border-radius: var(--card-radius);
      background: var(--ui-bg);

      > * {
        grid-area: 1/1;
      }

      > :first-child {
        inline-size: 100%;
        block-size: 100%;
        min-inline-size: 0;
        min-block-size: 0;
        place-self: center;
      }
    }

    .card__button {
      position: relative;
      place-self: flex-end;
      margin-inline-end: var(--size-1);
      margin-block-end: var(--size-1);
      box-shadow: var(--shadow-5);

      svg {
        transition: rotate 0.28s cubic-bezier(0.34, 1.56, 0.64, 1);
      }
    }

    .card__button:hover svg {
      rotate: 18deg;
    }

    .card__video {
      object-fit: cover;
    }

    .card__image {
      object-fit: contain;
      max-inline-size: var(--size-10);
    }

    .card--app .card__image {
      max-inline-size: var(--size-8);
    }

    .card--utility .card__image {
      max-inline-size: var(--size-7);
    }

    .card__subtitle {
      color: var(--text-secondary);
    }

    .card__date {
      font-size: var(--font-size-0);
      color: var(--text-secondary);
    }

    .card__meta {
      font-size: var(--font-size-0);
    }

    .card__meta-entry {
      display: flex;
      flex-direction: column;
    }

    .card__tools-list {
      gap: var(--size-1);
    }

    :where(.card--interaction, .card--icon) .card__date {
      display: none;
    }

    .card__meta-entry--press {
      display: flex;
      flex-direction: column;
    }

    .card__meta-entry--press dd {
      overflow: hidden;
      white-space: nowrap;
      text-overflow: ellipsis;
    }

    .card__link {
      color: var(--text-secondary);
    }
  }

  @keyframes card-appear-opacity {
    from {
      opacity: 0;
    }
  }

  @keyframes card-appear-transform {
    from {
      transform: translateY(var(--size-4));
    }
  }
</style>

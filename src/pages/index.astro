---
import SiteLayout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import ProjectCard from "../components/ProjectCard.astro";

const name = "Roey Biran";
const itemEntries = await getCollection("items");

const apps = itemEntries
  .filter(({ data }) => data.kind === "app")
  .sort((a, b) => a.data.title.localeCompare(b.data.title));

const utilities = itemEntries
  .filter(({ data }) => data.kind === "utility")
  .sort(
    (a, b) => (b.data.date?.getTime() ?? 0) - (a.data.date?.getTime() ?? 0),
  );

const allProjects = itemEntries
  .filter(({ data }) => data.kind === "project" && data.date)
  .sort(
    (a, b) => (b.data.date?.getTime() ?? 0) - (a.data.date?.getTime() ?? 0),
  );

const allInteractions = itemEntries
  .filter(({ data }) => data.kind === "interaction" && data.date)
  .sort(
    (a, b) => (b.data.date?.getTime() ?? 0) - (a.data.date?.getTime() ?? 0),
  );

const allIcons = itemEntries
  .filter(({ data }) => data.kind === "icon" && data.date)
  .sort(
    (a, b) => (b.data.date?.getTime() ?? 0) - (a.data.date?.getTime() ?? 0),
  );

const content: {
  title: string;
  key: string;
  items: CollectionEntry<"items">[];
}[] = [
  {
    title: "Apps",
    key: "apps",
    items: [...apps, ...utilities],
  },
  { title: "Projects", key: "projects", items: allProjects },
  { title: "Interactions", key: "interactions", items: allInteractions },
  { title: "Icons", key: "icons", items: allIcons },
];
---

<SiteLayout
  pageDescription={`${name}’s personal website`}
  currentURL={Astro.request.url}
>
  <h1 class="sr-only">{name}</h1>
  <div class="page-front__content">
    <div class="constrained padded">
      <div class="projects-grid | grid">
        {
          content.map(({ title, key, items }) => (
            <>
              <div class="card card--header | cardlike" data-section={key}>
                <h2 class="projects-grid__section-title | text-secondary">
                  {title}
                </h2>
              </div>
              {items.map((item) => (
                <ProjectCard item={item} sectionKey={key} />
              ))}
            </>
          ))
        }
      </div>
    </div>
  </div>
</SiteLayout>

<script>
  import gsap from "gsap";
  import { Flip } from "gsap/Flip";

  gsap.registerPlugin(Flip);

  let activeCard: HTMLElement | null = null;
  let activeFlip: gsap.core.Tween | null = null;
  let backgroundTween: gsap.core.Tween | null = null;
  let elevatedCard: HTMLElement | null = null;
  let ignoreNextClick = false;

  const backgroundElements = (card: HTMLElement) => [
    ...document.querySelectorAll<HTMLElement>(".site-header, .card"),
  ].filter((element) => element !== card);

  const backgroundBlur = () =>
    getComputedStyle(document.documentElement)
      .getPropertyValue("--size-px-2")
      .trim() || "2px";

  const blurBackground = (card: HTMLElement) => {
    const elements = backgroundElements(card);

    backgroundTween?.kill();
    backgroundTween = gsap.fromTo(
      elements,
      { filter: "blur(0px)" },
      {
        filter: `blur(${backgroundBlur()})`,
        duration: 0.35,
        ease: "power2.inOut",
        overwrite: "auto",
      },
    );
  };

  const clearBackgroundBlur = (card: HTMLElement) => {
    const elements = backgroundElements(card);

    backgroundTween?.kill();
    backgroundTween = gsap.fromTo(
      elements,
      { filter: `blur(${backgroundBlur()})` },
      {
        filter: "blur(0px)",
        duration: 0.35,
        ease: "power2.inOut",
        overwrite: "auto",
        onComplete: () => {
          gsap.set(elements, { clearProps: "filter" });
          backgroundTween = null;
        },
      },
    );
  };

  const animateFlip = (
    card: HTMLElement,
    inner: HTMLElement,
    update: () => void,
    onComplete?: () => void,
    ease = "back.out(1.2)",
  ) => {
    activeFlip?.progress(1).kill();
    elevatedCard?.removeAttribute("data-js-card-elevated");
    elevatedCard = card;
    card.setAttribute("data-js-card-elevated", "");

    const state = Flip.getState([
      inner,
      ...inner.querySelectorAll<HTMLElement>(
        "[data-js-card-media], [data-js-card-surface], [data-js-card-media-content]",
      ),
    ]);

    update();

    activeFlip = Flip.from(state, {
      absolute: true,
      duration: 0.35,
      ease,
      nested: true,
      props: "maxInlineSize",
      scale: true,
      onComplete: () => {
        onComplete?.();
        activeFlip = null;
      },
    });
  };

  const activeCardInner = () => {
    const inner = activeCard?.querySelector("[data-js-card-inner]");

    return inner instanceof HTMLElement ? inner : null;
  };

  const openCard = (card: HTMLElement) => {
    const inner = card.querySelector("[data-js-card-inner]");

    if (!(inner instanceof HTMLElement)) {
      return;
    }

    const previousCard = activeCard;

    animateFlip(card, inner, () => {
      previousCard?.removeAttribute("data-js-card-active");
      previousCard?.setAttribute("aria-expanded", "false");
      activeCard = card;
      card.setAttribute("data-js-card-opened", "");
      card.setAttribute("data-js-card-active", "");
      card.setAttribute("aria-expanded", "true");
      blurBackground(card);
    });

    inner.focus();
  };

  const closeCard = () => {
    if (!activeCard) {
      return;
    }

    const card = activeCard;
    const inner = card.querySelector("[data-js-card-inner]");

    if (!(inner instanceof HTMLElement)) {
      card.removeAttribute("data-js-card-active");
      card.removeAttribute("data-js-card-elevated");
      card.setAttribute("aria-expanded", "false");
      clearBackgroundBlur(card);
      elevatedCard = null;
      activeCard = null;
      return;
    }

    animateFlip(
      card,
      inner,
      () => {
        card.removeAttribute("data-js-card-active");
        card.setAttribute("aria-expanded", "false");
        activeCard = null;

        clearBackgroundBlur(card);
      },
      () => {
        card.removeAttribute("data-js-card-elevated");
        elevatedCard = null;
      },
      "power2.inOut",
    );
  };

  const closeFromOutsidePress = (event: MouseEvent | PointerEvent) => {
    const target = event.target;
    const inner = activeCardInner();

    if (inner && target instanceof Node && !inner.contains(target)) {
      ignoreNextClick = true;
      event.preventDefault();
      event.stopPropagation();
      closeCard();
    }
  };

  const closeFromOutsideClick = (event: MouseEvent) => {
    const target = event.target;
    const inner = activeCardInner();

    if (inner && target instanceof Node && !inner.contains(target)) {
      ignoreNextClick = false;
      event.preventDefault();
      event.stopPropagation();
      closeCard();
    }
  };

  document.addEventListener("pointerdown", closeFromOutsidePress, {
    capture: true,
  });
  document.addEventListener("mousedown", closeFromOutsidePress, {
    capture: true,
  });
  document.addEventListener("click", closeFromOutsideClick, {
    capture: true,
  });

  document.addEventListener("click", (event) => {
    if (ignoreNextClick) {
      ignoreNextClick = false;
      return;
    }

    const target = event.target;

    if (!(target instanceof Element)) {
      return;
    }

    if (activeCard) {
      const inner = activeCardInner();

      if (inner && !inner.contains(target)) {
        event.preventDefault();
        closeCard();
      }

      return;
    }

    const card = target.closest("[data-js-card]");

    if (card instanceof HTMLElement && !card.hasAttribute("data-js-card-active")) {
      const interactiveTarget = target.closest("a, button");

      if (!interactiveTarget) {
        event.preventDefault();
        openCard(card);
      }
    }
  });

  document.addEventListener("focusin", () => {
    if (activeCard && !activeCard.contains(document.activeElement)) {
      closeCard();
    }
  });

  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape" && activeCard) {
      event.preventDefault();
      closeCard();
    }
  });
</script>

<style is:global>
  .page-front__content {
    padding-block: var(--size-4) var(--size-8);
  }

  .main--home {
    --card-enter-opacity-duration: calc(
      var(--sneeze) + var(--duration-quick-2) + var(--duration-quick-2)
    );
    --card-enter-transform-duration: calc(
      var(--sneeze) + var(--duration-gentle-2) + var(--duration-moderate-1)
    );
    --card-enter-stagger: calc(var(--duration-quick-1) + var(--jiffy));

    .projects-grid {
      list-style: none;
      --grid-item-min: var(--size-fluid-8);
      --grid-fit: auto-fit;
      gap: var(--bleed);
      grid-auto-rows: var(--size-12);
    }

    .card {
      opacity: 1;
      transform: translateY(0);
      animation:
        card-appear-opacity var(--card-enter-opacity-duration) var(--ease-2)
          both,
        card-appear-transform var(--card-enter-transform-duration) var(--ease-4)
          both;
      animation-delay: calc(sibling-index() * var(--card-enter-stagger));
    }

    .card--header {
      display: grid;
      place-content: center;
      min-block-size: var(--size-12);
      padding: var(--bleed);
      text-align: center;
    }

    .card--header .projects-grid__section-title {
      font-size: var(--font-size-1);
    }

    .card {
      position: relative;
    }

    .card__inner {
      block-size: 100%;
      overflow: clip;
      border: var(--border);
      border-radius: var(--card-radius);
      background: var(--app-bg);
      color: inherit;
      outline: 0;
    }

    [data-js-card-opened],
    [data-js-card-active] {
      animation: none;
      transform: none;
    }

    [data-js-card-elevated] {
      z-index: 2147483647;
    }

    [data-js-card-elevated]::before {
      content: "";
      position: absolute;
      inset: 0;
      z-index: 0;
      pointer-events: none;
      border: var(--border-dashed);
      border-radius: var(--card-radius);
      background: var(--ui-bg);
    }

    [data-js-card-active] .card__inner {
      position: fixed;
      inset-block-start: 50%;
      inset-inline-start: 50%;
      z-index: 1;
      transform: translate(-50%, -50%);
      inline-size: min(var(--size-content-3), calc(100% - (2 * var(--bleed))));
      block-size: auto;
      max-block-size: calc(100dvb - (2 * var(--bleed)));
      overflow: auto;
      box-shadow: var(--shadow-5);
    }

    .card__media {
      position: relative;
      block-size: 100%;
    }

    [data-js-card-active] .card__media {
      block-size: auto;
      border-block-end: var(--border);
      background: var(--ui-bg);
    }

    .card__surface {
      block-size: 100%;
      overflow: hidden;
      display: grid;
      background: var(--ui-bg);

      > * {
        grid-area: 1/1;
      }

      > :first-child {
        inline-size: 100%;
        block-size: 100%;
        min-inline-size: 0;
        min-block-size: 0;
        place-self: center;
      }
    }

    [data-js-card-active] .card__surface > :first-child {
      inline-size: 100%;
      block-size: auto;
      max-inline-size: 100%;
    }

    .card__details {
      display: none;
      padding: var(--bleed);

      > * + * {
        border-block-start: var(--border-dashed);
        padding-block-start: var(--size-2);
        margin-block-start: var(--size-2);
      }
    }

    [data-js-card-active] .card__details {
      display: block;
    }

    .card__video {
      object-fit: cover;
    }

    .card__image {
      object-fit: contain;
      max-inline-size: var(--size-10);
    }

    .card--app .card__image {
      max-inline-size: var(--size-8);
    }

    .card--utility .card__image {
      max-inline-size: var(--size-7);
    }

    .card__subtitle {
      color: var(--text-secondary);
    }

    .card__date {
      font-size: var(--font-size-0);
      color: var(--text-secondary);
    }

    .card__meta {
      font-size: var(--font-size-0);
    }

    .card__meta-entry {
      display: flex;
      flex-direction: column;
    }

    .card__tools-list {
      gap: var(--size-1);
    }

    :where(.card--interaction, .card--icon) .card__date {
      display: none;
    }

    .card__meta-entry--press {
      display: flex;
      flex-direction: column;
    }

    .card__meta-entry--press dd {
      overflow: hidden;
      white-space: nowrap;
      text-overflow: ellipsis;
    }

    .card__link {
      color: var(--text-secondary);
    }
  }

  @keyframes card-appear-opacity {
    from {
      opacity: 0;
    }
  }

  @keyframes card-appear-transform {
    from {
      transform: translateY(var(--size-4));
    }
  }
</style>

---
import "open-props/style";
import "open-props/durations";
import "../styles/global.css";
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteHead from "../components/SiteHead.astro";
import { extractSlug } from "../utils/extractSlug";

interface Props {
  pageDescription: string;
  ogImage: string;
  currentURL: string;
}

const { pageDescription, ogImage, currentURL }: Props = Astro.props;

const slug = extractSlug(currentURL) || "home";
const bodyClass = `body--${slug}`;
const mainClass = `main--${slug}`;
---

<!doctype html>
<html lang="en">
  <SiteHead
    pageDescription={pageDescription}
    ogImage={ogImage}
    currentURL={currentURL}
  />
  <body class={bodyClass}>
    <SiteHeader />
    <main class={mainClass}>
      <slot />
    </main>
    <SiteFooter />
  </body>
</html>

---
import "open-props/style";
import "../styles/global.css";
import SiteFooter from "../components/SiteFooter.astro";
import SiteHead from "../components/SiteHead.astro";
import { extractSlug } from "../utils/extractSlug";

interface Props {
  pageTitle: string;
  pageDescription: string;
  ogImage: string;
  currentURL: string;
  footerName: string;
  xHandle: string;
  themeMode?: "system" | "light" | "dark";
}

const {
  pageTitle,
  pageDescription,
  ogImage,
  currentURL,
  footerName,
  xHandle,
  themeMode = "system",
}: Props = Astro.props;
const slug = extractSlug(currentURL);
const bodyClass = `body--${slug}`;
const mainClass = `main--${slug}`;
---

<!doctype html>
<html lang="en" data-theme-mode={themeMode}>
  <SiteHead
    pageTitle={pageTitle}
    pageDescription={pageDescription}
    ogImage={ogImage}
    currentURL={currentURL}
  />
  <body class={bodyClass}>
    <slot name="header" />
    <main class={mainClass}>
      <slot />
    </main>
    <SiteFooter copyrightName={footerName} xHandle={xHandle} />
  </body>
</html>

<script src="../scripts/script.ts"></script>
